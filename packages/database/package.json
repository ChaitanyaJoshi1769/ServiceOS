    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.11.2",
    "typescript": "^5.3.2"
  }
}
