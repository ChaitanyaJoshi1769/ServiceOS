{
  "name": "@serviceos/database",
  "version": "0.1.0",
  "description": "Database layer for ServiceOS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "migrate": "node dist/migrate.js",
