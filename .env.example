# ServiceOS Environment Configuration

# API
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/serviceos
REDIS_URL=redis://localhost:6379

# AI Models
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# Authentication
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=...
AUTH0_CLIENT_SECRET=...

# Storage
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=serviceos-documents
AWS_REGION=us-east-1

# Logging
LOG_LEVEL=info
SENTRY_DSN=...

# Feature Flags
ENABLE_VECTOR_SEARCH=true
ENABLE_ASYNC_WORKFLOWS=true
ENABLE_MULTI_AGENT_COORDINATION=true
